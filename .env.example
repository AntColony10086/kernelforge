# Drop your DeepSeek API key here (no surrounding quotes), then rename this file to .env
# Real .env is gitignored.
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional — leave unset to use defaults
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# DEEPSEEK_MODEL_PRIMARY=deepseek-v4-flash
# DEEPSEEK_MODEL_ESCALATION=deepseek-v4-pro

# Optional — TrueFoundry AI Gateway (filled in on D1 after signup; falls back to local_gateway if absent)
# TFY_GATEWAY_BASE_URL=
# TFY_GATEWAY_API_KEY=
